.wrap{max-width:680px;margin:0 auto;padding:24px 18px;}
.last-updated{font-size:11px;color:var(--dim);margin-bottom:24px;padding:8px 12px;background:var(--s2);border-radius:8px;display:inline-block;}
h1{font-size:20px;font-weight:900;margin-bottom:6px;}
h2{font-size:14px;font-weight:900;margin:28px 0 10px;padding-left:10px;border-left:3px solid var(--red);color:var(--txt);}
