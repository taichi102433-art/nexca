ul{padding-left:18px;margin-bottom:10px;}
li{font-size:13px;color:rgba(255,255,255,0.75);margin-bottom:6px;line-height:1.8;}
table{width:100%;border-collapse:collapse;margin:12px 0;font-size:12px;}
th{background:var(--s2);padding:9px 10px;text-align:left;font-weight:700;border:1px solid rgba(255,255,255,0.07);}
td{padding:9px 10px;border:1px solid rgba(255,255,255,0.07);color:rgba(255,255,255,0.7);vertical-align:top;}
.note{background:var(--s2);border:1.5px solid rgba(255,255,255,0.06);border-radius:10px;padding:12px 14px;margin:14px 0;}
.note p{margin:0;font-size:12px;color:var(--dim);}
.contact{margin-top:28px;background:var(--s1);border:1.5px solid rgba(255,255,255,0.06);border-radius:12px;padding:16px;}
